{{! @glint-nocheck }}
<dialog
  id='modal'
  {{on 'cancel' this.handleModalCancel}}
  data-modal='{{this.activeModal.type}}'
>
  {{#if this.activeModal.type}}
    {{#if (eq this.activeModal.type 'confirm')}}
      <Modal::Types::Confirm @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'info')}}
      <Modal::Types::Info @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'input')}}
      <Modal::Types::Input @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'icon-select')}}
      <Modal::Types::IconSelect @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'meme-select')}}
      <Modal::Types::MemeSelect @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'link-insert')}}
      <Modal::Types::LinkInsert @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'list')}}
      <Modal::Types::List @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'image-insert')}}
      <Modal::Types::ImageInsert @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'post-preview')}}
      <Modal::Types::PostPreview @options={{this.activeModal.options}} />
    {{else if (eq this.activeModal.type 'user-profile')}}
      <Modal::Types::UserProfile @options={{this.activeModal.options}} />
    {{/if}}
  {{/if}}
</dialog>
<button
  id='modal-backdrop'
  type='button'
  {{on 'click' this.handleModalCancel}}
  aria-hidden='true'
/>
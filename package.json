{
  "name": "potber-client",
  "version": "1.24.0",
  "private": true,
  "description": "An SPA client for the german board forum.mods.de built with Ember.js.",
  "repository": "https://github.com/potber/potber-client",
  "license": "GNU General Public License",
  "author": "https://github.com/spuxx-dev",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "start:remote": "vite --mode development:remote --host 0.0.0.0",
    "start:mobile": "vite --mode development:mobile --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "build": "vite build --mode production",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "prettier:check": "prettier --check . --plugin prettier-plugin-ember-template-tag",
    "prettier:format": "prettier --write . --plugin prettier-plugin-ember-template-tag",
    "test": "vite build --mode development && ember test --path dist",
    "test:coverage": "COVERAGE=true vite build --mode development && ember test --path dist",
    "update": "npx npm-check-updates -u",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@ember-intl/vite": "^0.5.4",
    "@ember/optional-features": "^3.0.0",
    "@ember/render-modifiers": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.13",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.3",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/vite": "^1.6.1",
    "@fortawesome/ember-fontawesome": "^3.1.0",
    "@fortawesome/fontawesome-common-types": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@glimmer/component": "^2.0.0",

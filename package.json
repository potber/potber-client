    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "postcss": "^8.4.32",
    "prettier": "^3.0.3",
    "prettier-plugin-ember-template-tag": "^1.1.0",
    "qunit": "^2.22.0",
    "qunit-dom": "^2.0.0",
    "reactiveweb": "^1.6.1",
    "semver": "^7.6.0",
    "tinygesture": "^2.0.0",
    "typescript": "^5.9.3",
    "uuid": "^10.0.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": "24.x"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "katex": "^0.16.21"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}
